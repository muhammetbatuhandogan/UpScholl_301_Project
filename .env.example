# Copy to ".env" at repo root and adjust if needed (".env" is gitignored).
# Used by docker compose variable substitution when you set these in .env

POSTGRES_USER=upscholl
POSTGRES_PASSWORD=upscholl_dev
POSTGRES_DB=upscholl
POSTGRES_PORT=5432

# For FastAPI / SQLAlchemy (sync driver example):
# DATABASE_URL=postgresql://upscholl:upscholl_dev@localhost:5432/upscholl
# Async (asyncpg) example:
# DATABASE_URL=postgresql+asyncpg://upscholl:upscholl_dev@localhost:5432/upscholl
