# Copy to ".env" at repo root and adjust if needed (".env" is gitignored).
# Used by docker compose variable substitution when you set these in .env

POSTGRES_USER=upscholl
POSTGRES_PASSWORD=upscholl_dev
POSTGRES_DB=upscholl
POSTGRES_PORT=5432

# For FastAPI (set in shell or IDE before `uvicorn`; default in code uses 127.0.0.1:5432):
# DATABASE_URL=postgresql://upscholl:upscholl_dev@127.0.0.1:5432/upscholl
#
# Local OTP: when true, POST /api/auth/otp/request includes `debug_code` in JSON (do not use in production).
# OTP_DEBUG=true
#
# Netgsm SMS (OTP + SOS). When unset, SMS sending is skipped (OTP still works with OTP_DEBUG).
# NETGSM_USERCODE=
# NETGSM_PASSWORD=
# NETGSM_MSGHEADER=UPSCHOLL
#
# Access / refresh token TTL (optional).
# ACCESS_TOKEN_TTL_SECONDS=86400
# REFRESH_TOKEN_TTL_DAYS=30
#
# Offline emergency guide manifest version override (optional).
# GUIDE_CONTENT_VERSION=1.0.0
#
# POST /api/notifications/run-due (header X-Internal-Cron) batch job secret:
# CRON_SECRET=change_me_in_production
#
# Run APScheduler inside uvicorn every 15m (same logic as run-due). Default off.
# ENABLE_NOTIFICATION_SCHEDULER=true

